# MySQL (required)
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_mysql_password
MYSQL_DATABASE=medispan_test

# Google Drive folder IDs (optional locally — without credentials, uses assets/)
# Required on GitHub Actions via secrets
GDRIVE_ZIP_ROOT_FOLDER_ID=
GDRIVE_XLS_ROOT_FOLDER_ID=
GDRIVE_SQL_ROOT_FOLDER_ID=

# Service account — downloads ZIP/XLS from Drive
GOOGLE_APPLICATION_CREDENTIALS=gdrive-credentials.json

# Upload — run once after adding oauth-client.json:
#   python authorize_drive.py
# This creates google-oauth-token.json automatically (gitignored).
# For GitHub Actions, copy the 3 OAuth values printed by authorize_drive.py into secrets.

# Pipeline date folders (optional; defaults to today)
# PIPELINE_YEAR=2026
# PIPELINE_MONTH=6
