# MySQL (required)
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_mysql_password
MYSQL_DATABASE=medispan_test

# Deploy target (see deploy_config.py)
#   mock        → local stand-in schema (default)
#   production  → real RDS when DEPLOY_ALLOW_PRODUCTION=true; otherwise MOCKED → mock schema
#   none        → skip deploy (Drive upload only)
DEPLOY_TARGET=mock
DEPLOY_MOCK_DATABASE=mock-rxmax
DEPLOY_PRODUCTION_DATABASE=
DEPLOY_ALLOW_PRODUCTION=false
# false = run deploy on GitHub Actions against the runner's temporary MySQL (recommended).
# true  = skip deploy on CI (you must run sync_mock_from_drive.py locally to test deploy).
DEPLOY_SKIP_ON_CI=false

# Google Drive folder IDs (optional locally — without credentials, uses assets/)
# Required on GitHub Actions via secrets
GDRIVE_ZIP_ROOT_FOLDER_ID=
GDRIVE_XLS_ROOT_FOLDER_ID=
GDRIVE_SQL_ROOT_FOLDER_ID=

# Service account — downloads ZIP/XLS from Drive
GOOGLE_APPLICATION_CREDENTIALS=gdrive-credentials.json

# Upload — run once after adding oauth-client.json:
#   python authorize_drive.py
# This creates google-oauth-token.json automatically (gitignored).
# For GitHub Actions, copy the 3 OAuth values printed by authorize_drive.py into secrets.

# Pipeline date folders — pass on CLI instead:
#   python main.py 2026 4
#   python sync_mock_from_drive.py 2026 4
# PIPELINE_YEAR=2026
# PIPELINE_MONTH=4
